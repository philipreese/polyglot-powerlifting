# SvelteKit Environment Variables
# Copy this to .env and fill in your values

# The base URL for the FastAPI backend
VITE_API_URL=http://localhost:8000

# Standardized Supabase credentials (Vite configured to expose SUPABASE_ prefix)
SUPABASE_URL=https://your-project-url.supabase.co
SUPABASE_ANON_KEY=your-anon-key

# Authentication Redirect (Optional override)
# Ensure your SITE_URL and Redirect URLs are configured in the Supabase Dashboard:
# Authentication -> URL Configuration -> Site URL & Redirect URLs
VITE_SITE_URL=http://localhost:5173

# SvelteKit Environment Variables
# Copy this to .env and fill in your values

# The base URL for the FastAPI backend
VITE_API_URL=http://localhost:8000

# Standardized Supabase credentials (Vite configured to expose SUPABASE_ prefix)
SUPABASE_URL=https://your-project-url.supabase.co
SUPABASE_ANON_KEY=your-anon-key

# SvelteKit Public variables (Idiomatic standard for browser exposure)
PUBLIC_SUPABASE_URL=https://your-project-url.supabase.co
PUBLIC_SUPABASE_ANON_KEY=your-anon-key

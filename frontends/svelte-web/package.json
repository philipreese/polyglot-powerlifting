{
	"name": "svelte-web",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"gen-types": "pnpm dlx openapi-zod-client http://localhost:8000/openapi.json -o src/lib/schemas/openapi.ts"
	},
	"devDependencies": {
		"@playwright/test": "^1.58.2",
		"@sveltejs/adapter-auto": "^7.0.0",
		"@sveltejs/kit": "^2.50.2",
		"@sveltejs/vite-plugin-svelte": "^6.2.4",
		"@tailwindcss/vite": "^4.2.1",
		"@types/node": "^25.3.1",
		"lucide-svelte": "^0.575.0",
		"prettier": "^3.8.1",
		"prettier-plugin-svelte": "^3.5.0",
		"svelte": "^5.51.0",
		"svelte-check": "^4.3.6",
		"tailwindcss": "^4.2.1",
		"typescript": "^5.9.3",
		"vite": "^7.3.1"
	},
	"dependencies": {
		"@supabase/supabase-js": "^2.97.0",
		"@zodios/core": "^10.9.6",
		"mode-watcher": "^1.1.0",
		"zod": "^4.3.6"
	}
}
